# Público: enlace de invitación a Discord (CTAs en hero, footer, log). Obligatorio en producción real.
NEXT_PUBLIC_DISCORD_INVITE_URL=

# Opcional: ID de Google Analytics / GA4 (ej. G-XXXXXXXXXX).
NEXT_PUBLIC_GA_ID=

# Público: etiqueta de estado del nodo Quito en dashboard-style UI (ej. OPERATIONAL).
NEXT_PUBLIC_QUITO_NODE_STATUS=OPERATIONAL

# Opcional: URL canónica del sitio (metadata Open Graph).
# NEXT_PUBLIC_SITE_URL=

# Opcional: perfil de X/Twitter.
# NEXT_PUBLIC_X_URL=

# Opcional: métricas mostradas en Active Nodes.
# NEXT_PUBLIC_TOTAL_MEMBERS=
# NEXT_PUBLIC_NEXT_SYNC=
